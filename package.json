{
  "name": "team-synergy-shiny-showcase",
  "description": "Team Synergy PokeMMO Shiny Hunting Community - Track shinies, view streamers, generate counters",
  "keywords": [
    "pokemmo",
    "shiny pokemon",
    "pokemon",
    "shiny",
    "hunting",
    "team",
    "synergy",
    "twitch",
    "streaming",
    "mmo"
  ],
  "author": "Team Synergy",
  "homepage": "https://synergymmo.com",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node src/utils/sitemap-builder.js && vite build && node scripts/prerender.mjs",
    "preview": "vite preview",
    "sitemap": "node src/utils/sitemap-builder.js",
    "MergeData": "node scripts/mergeShinyData.js",
    "TestMergeData": "node scripts/mergeShinyData.js --test",
    "MergeUserData": "node scripts/mergeShinyData.js --user=%npm_config_user%",
    "resourceeditor": "node scripts/resourcesEditorServer.mjs",
    "sendBountiesToDiscord": "node scripts/sendBountiesToDiscord.js"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-virtual": "^3.13.18",
    "discord.js": "^14.25.1",
    "get-image-colors": "^4.0.1",
    "gif-encoder-2": "^1.0.5",
    "gif.js.optimized": "^1.0.1",
    "gifuct-js": "^2.1.2",
    "jszip": "^3.10.1",
    "node-fetch": "^2.7.0",
    "omggif": "^1.0.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "express": "^4.18.2",
    "open": "^9.1.0",
    "puppeteer": "^24.2.0",
    "vite": "^6.0.0"
  }
}
